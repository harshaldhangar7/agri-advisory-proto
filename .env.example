# Database Configuration
DATABASE_URL=mysql+pymysql://agriuser:your_password@localhost:3306/agri?charset=utf8mb4

# MySQL Root Password (for automatic database setup)
# This is only used by setup_database.py to create the database and user
# Leave empty if root has no password
DATABASE_ROOT_PASS=

# API Security
# Change this to a strong random string in production
API_KEY=default-dev-key

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Configuration (for CORS)
FRONTEND_URL=http://localhost:5173
